# Supabase PostgreSQL (Nitro Labs System)
# Replace placeholders only. Never commit a real .env file.
# Copy exact host from Supabase Connect (pooler may be aws-0 or aws-1 for your region).
# If the password contains @ # % $ etc., URL-encode it (^=%5E @=%40 %=%25 $=%24).
DATABASE_URL="postgresql://postgres.ybpcldwsvifzryhdqdxj:YOUR-URL-ENCODED-PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:YOUR-URL-ENCODED-PASSWORD@db.ybpcldwsvifzryhdqdxj.supabase.co:5432/postgres"

# App auth for the single-owner login gate.
AUTH_USERNAME="admin"
AUTH_PASSWORD="CHANGE_ME"
AUTH_SECRET="GENERATE_WITH_NODE_CRYPTO_RANDOM_BYTES"

# Supabase Storage for SKU photos (server-side only; never prefix with NEXT_PUBLIC_).
# SUPABASE_URL is the project API URL (Project Settings -> API).
# SUPABASE_STORAGE_KEY can be the anon/publishable key: the "sku-photos" bucket has
# its own RLS policies scoping anon insert/update/delete to just that one bucket.
# Without these two set, the photo upload UI stays disabled and the rest of the app
# is unaffected.
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_STORAGE_KEY="YOUR-ANON-OR-PUBLISHABLE-KEY"

# Optional legacy local SQLite value, only if schema provider is switched back to sqlite:
# DATABASE_URL="file:./dev.db"
